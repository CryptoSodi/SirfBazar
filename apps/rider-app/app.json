{
  "expo": {
    "name": "SirfBazar Rider",
    "slug": "sirfbazar-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "sirfbazar-rider",
    "splash": {
      "backgroundColor": "#059669",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pk.sirfbazar.rider",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SirfBazar Rider shares your location with the customer during active deliveries."
      }
    },
    "android": {
      "package": "pk.sirfbazar.rider",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SirfBazar Rider shares your location with the customer during active deliveries."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "493f7f43-898b-4c40-b9a4-bc0c51bf3313"
      }
    }
  }
}
