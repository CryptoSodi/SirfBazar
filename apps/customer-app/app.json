{
  "expo": {
    "name": "SirfBazar",
    "slug": "sirfbazar-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "sirfbazar",
    "splash": {
      "backgroundColor": "#059669",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pk.sirfbazar.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SirfBazar uses your location to show shops and products near you."
      }
    },
    "android": {
      "package": "pk.sirfbazar.customer",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBdkMmH4b_cdnLIQfLFS2zDK84tNvqrbAs"
        }
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SirfBazar uses your location to show shops and products near you."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "6434c258-86f8-4cc6-8d42-cd89dc0e31c2"
      }
    }
  }
}
