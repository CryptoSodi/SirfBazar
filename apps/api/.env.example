# SirfBazar API configuration
# Copy to .env and adjust per environment.

# PostgreSQL everywhere. Options for local development:
#   - docker compose up -d   (postgres on localhost:5432, matches the URL below)
#   - or paste your Render Postgres EXTERNAL connection string here
# On Render the blueprint injects DATABASE_URL from the managed database automatically.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sirfbazar"

PORT=3001
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# OTP provider: "mock" for development, "external" once the real provider is supplied.
OTP_PROVIDER=mock
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
# External OTP provider credentials (provided later; keep out of source control)
OTP_PROVIDER_BASE_URL=
OTP_PROVIDER_API_KEY=

# Google auth: "mock" accepts "mock:<email>:<name>" in dev. Set to "google" in
# production to verify real Google ID tokens. GOOGLE_CLIENT_ID must equal the
# Web OAuth client ID used by the website (it is the token "aud" we verify).
GOOGLE_AUTH_PROVIDER=mock
GOOGLE_CLIENT_ID=

# Business defaults (amounts in paisa: 100 paisa = 1 PKR)
DEFAULT_DELIVERY_BASE_FEE_PAISA=5000
DEFAULT_DELIVERY_PER_KM_FEE_PAISA=1500
DEFAULT_SERVICE_FEE_PAISA=1000
SMALL_ORDER_THRESHOLD_PAISA=30000
SMALL_ORDER_FEE_PAISA=3000
DEFAULT_COMMISSION_PERCENT=10
MERCHANT_ACCEPT_TIMEOUT_MINUTES=10

# Local dev:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production (website + admin on Vercel, API behind Cloudflare Tunnel):
# CORS_ORIGINS=https://sirfbazar.com,https://www.sirfbazar.com,https://admin.sirfbazar.com,https://shop.sirfbazar.com,http://localhost:3000,http://localhost:5173,http://localhost:5174
