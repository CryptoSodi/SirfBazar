NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Browser key restricted to HTTP referrers + "Maps JavaScript API". Optional — the
# "Pin on map" button only appears when this is set.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Web OAuth Client ID for "Sign in with Google". When unset, a dev mock button is shown.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
