{
  "expo": {
    "name": "SirfBazar Merchant",
    "slug": "sirfbazar-merchant",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "sirfbazar-merchant",
    "splash": {
      "backgroundColor": "#0f172a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pk.sirfbazar.merchant"
    },
    "android": {
      "package": "pk.sirfbazar.merchant"
    },
    "plugins": [
      "@react-native-google-signin/google-signin"
    ]
  }
}
