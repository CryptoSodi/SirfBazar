{
  "expo": {
    "name": "SirfBazar Merchant",
    "slug": "sirfbazar-merchant",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "sirfbazar-merchant",
    "splash": {
      "backgroundColor": "#0f172a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pk.sirfbazar.merchant"
    },
    "android": {
      "package": "pk.sirfbazar.merchant"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SirfBazar Merchant uses your location to pin your shop on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SirfBazar Merchant needs photo access to add your shop-front picture.",
          "cameraPermission": "SirfBazar Merchant needs camera access to take your shop-front picture."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "3dd9ec80-1b9c-418a-bfb2-fc124b20a765"
      }
    }
  }
}
